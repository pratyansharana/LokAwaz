{
  "expo": {
    "name": "LokAwaz",
    "slug": "LokAwaz",
    "scheme": "com.lokawaz.app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCifJyz7P8-up7zmUHqSmS9glWmzD49rrc"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.pratyansh_rana.LokAwaz",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
    "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "firebaseProjectId": "lokawaz-506ba",
      "eas": {
        "projectId": "bee6e42e-87d8-4bec-aad9-979aeecc8f0f",
        "model":"./assets/pothole.tflite"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow LokAwaz to use the camera for automated civic issue detection."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LokAwaz to use your location to map civic issues while driving."
        }
      ],
      "expo-asset",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "owner": "pratyansh_rana"
  }
}